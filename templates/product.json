    "custom_liquid_BzKAQJ": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<!-- =========================================================\n     SECTION \"PRINCIPES ACTIFS\" v2 – style packaging (bleu marine + crème)\n     Fond blanc. À coller dans une section \"Custom Liquid\" (thème Impact).\n     Tout est scoppé .pa- => aucun conflit avec ton thème.\n     Icônes = SVG intégrés (navy), rien à héberger.\n========================================================= -->\n\n<link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n\n<section class=\"pa-actifs\">\n  <div class=\"pa-wrap\">\n\n    <header class=\"pa-head\">\n      <span class=\"pa-overline\">\n        <svg viewBox=\"0 0 24 24\" width=\"16\" height=\"16\" fill=\"currentColor\"><circle cx=\"6\" cy=\"9\" r=\"2\"/><circle cx=\"12\" cy=\"7\" r=\"2\"/><circle cx=\"18\" cy=\"9\" r=\"2\"/><ellipse cx=\"12\" cy=\"16\" rx=\"5\" ry=\"4\"/></svg>\n        Soutien naturel\n      </span>\n      <h2 class=\"pa-title\">8 Principes Actifs Puissants</h2>\n      <p class=\"pa-sub\">Chaque principe actif a été soigneusement sélectionné pour ses effets.</p>\n    </header>\n\n    <div class=\"pa-grid\" id=\"paGrid\">\n\n      <article class=\"pa-card\">\n        <span class=\"pa-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22V9\"/><path d=\"M12 9c-3 0-5-2-5-4 2 0 3 1 3 1s0-3 2-4c2 1 2 4 2 4s1-1 3-1c0 2-2 4-5 4z\"/><path d=\"M8 22h8\"/></svg>\n        </span>\n        <h3 class=\"pa-card-title\">Écorce de Pau d'Arco</h3>\n        <p class=\"pa-card-text\">Propriétés antifongiques naturelles, aide à compenser les infections à levures.</p>\n      </article>\n\n      <article class=\"pa-card\">\n        <span class=\"pa-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M11 20c-4 0-7-3-7-7 4 0 7 3 7 7z\"/><path d=\"M13 20c4 0 7-3 7-7-4 0-7 3-7 7z\"/><path d=\"M12 20V8\"/><path d=\"M12 8c0-2 1-4 3-4\"/></svg>\n        </span>\n        <h3 class=\"pa-card-title\">Gingembre</h3>\n        <p class=\"pa-card-text\">Propriétés antifongiques puissantes, aide à lutter contre les infections à levures.</p>\n      </article>\n\n      <article class=\"pa-card\">\n        <span class=\"pa-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"7\" r=\"3\"/><path d=\"M12 4V2M12 10v2M9 7H7M15 7h2M9.5 4.5 8 3M14.5 4.5 16 3M9.5 9.5 8 11M14.5 9.5 16 11\"/><path d=\"M12 12v10\"/></svg>\n        </span>\n        <h3 class=\"pa-card-title\">Pissenlit</h3>\n        <p class=\"pa-card-text\">Soutient la santé du foie et des reins, aide à éliminer les toxines et soulage les inconforts digestifs.</p>\n      </article>\n\n      <article class=\"pa-card\">\n        <span class=\"pa-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 8c-1.5-2-4-2-5.5-.5C4 9.5 5 14 7.5 17c1.5 1.8 3 2.5 4.5 2.5s3-.7 4.5-2.5C19 14 20 9.5 17.5 7.5 16 6 13.5 6 12 8z\"/><path d=\"M12 8c0-2 1-3.5 3-4\"/></svg>\n        </span>\n        <h3 class=\"pa-card-title\">Vinaigre de Cidre de Pomme</h3>\n        <p class=\"pa-card-text\">Riche en enzymes et probiotiques, aide à équilibrer le pH et soutient la digestion.</p>\n      </article>\n\n      <article class=\"pa-card\">\n        <span class=\"pa-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 21V11\"/><path d=\"M12 11c-2.5 0-4.5-2-4.5-4.5C10 6.5 12 8.5 12 11z\"/><path d=\"M12 11c2.5 0 4.5-2 4.5-4.5C14 6.5 12 8.5 12 11z\"/><path d=\"M12 14c-2 0-3.5-1.5-3.5-3.5\"/><path d=\"M12 14c2 0 3.5-1.5 3.5-3.5\"/></svg>\n        </span>\n        <h3 class=\"pa-card-title\">Hydraste du Canada</h3>\n        <p class=\"pa-card-text\">Puissant antimicrobien naturel, aide à combattre les bactéries et les infections à levures.</p>\n      </article>\n\n      <article class=\"pa-card\">\n        <span class=\"pa-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"8\" r=\"2.5\"/><path d=\"M12 5.5c0-2 1.5-3.5 3.5-3.5-.2 2-1.5 3.3-3.5 3.5z\"/><path d=\"M12 5.5c0-2-1.5-3.5-3.5-3.5.2 2 1.5 3.3 3.5 3.5z\"/><path d=\"M9.6 9.2 6 12M14.4 9.2 18 12\"/><path d=\"M12 10.5V22\"/></svg>\n        </span>\n        <h3 class=\"pa-card-title\">Racine de Guimauve</h3>\n        <p class=\"pa-card-text\">Apaise l'inflammation, calme la toux et soutient la santé respiratoire et digestive.</p>\n      </article>\n\n      <!-- Cachées : révélées au clic -->\n      <article class=\"pa-card pa-hidden\">\n        <span class=\"pa-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 3c3.5 4.5 6 7.5 6 11a6 6 0 0 1-12 0c0-3.5 2.5-6.5 6-11z\"/></svg>\n        </span>\n        <h3 class=\"pa-card-title\">Eau Déionisée</h3>\n        <p class=\"pa-card-text\">Hydrate et aide à l'absorption optimale des nutriments.</p>\n      </article>\n\n      <article class=\"pa-card pa-hidden\">\n        <span class=\"pa-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><ellipse cx=\"12\" cy=\"12\" rx=\"8\" ry=\"6\"/><path d=\"M12 6v12M6 9l12 6M6 15l12-6\"/></svg>\n        </span>\n        <h3 class=\"pa-card-title\">Acide Citrique</h3>\n        <p class=\"pa-card-text\">Aide à équilibrer le pH du corps et favorise un système immunitaire sain.</p>\n      </article>\n\n    </div>\n\n    <div class=\"pa-cta\">\n      <button class=\"pa-btn\" id=\"paToggle\" type=\"button\">Afficher tous les actifs</button>\n    </div>\n\n  </div>\n</section>\n\n<style>\n  .pa-actifs{\n    --navy:#20436B;\n    --navy-dark:#16304C;\n    --cream:#EDE3CF;\n    --cream-soft:#F6F0E4;\n    --text:#48566A;\n    --border:#E9E2D2;\n    background:#FFFFFF;\n    padding:66px 20px;\n  }\n  .pa-actifs, .pa-actifs *{box-sizing:border-box;font-family:'Montserrat',-apple-system,Segoe UI,Roboto,sans-serif;}\n  .pa-wrap{max-width:1120px;margin:0 auto;}\n\n  .pa-head{text-align:center;margin-bottom:42px;}\n  .pa-overline{\n    display:inline-flex;align-items:center;gap:8px;\n    color:var(--navy);\n    background:var(--cream-soft);\n    border:1px solid var(--border);\n    padding:7px 16px;border-radius:40px;\n    font-size:13px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;\n    margin-bottom:18px;\n  }\n  .pa-title{\n    color:var(--navy);\n    font-weight:800;\n    font-size:clamp(27px,4.6vw,44px);\n    line-height:1.12;\n    letter-spacing:-.01em;\n    margin:0 0 14px;\n  }\n  .pa-sub{\n    color:var(--text);\n    font-size:clamp(15px,2.3vw,17px);\n    font-weight:500;\n    margin:0 auto;max-width:600px;line-height:1.5;\n  }\n\n  .pa-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}\n\n  .pa-card{\n    background:#fff;\n    border:1px solid var(--border);\n    border-radius:16px;\n    padding:28px 24px;\n    box-shadow:0 8px 24px rgba(32,67,107,.05);\n    transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease;\n  }\n  .pa-card:hover{\n    transform:translateY(-5px);\n    box-shadow:0 18px 40px rgba(32,67,107,.13);\n    border-color:var(--cream);\n  }\n\n  .pa-ic{\n    display:flex;align-items:center;justify-content:center;\n    width:52px;height:52px;border-radius:14px;\n    background:var(--cream-soft);\n    color:var(--navy);\n    margin-bottom:18px;\n    transition:background .25s ease,color .25s ease;\n  }\n  .pa-ic svg{width:26px;height:26px;}\n  .pa-card:hover .pa-ic{background:var(--navy);color:#fff;}\n\n  .pa-card-title{\n    color:var(--navy-dark);\n    font-weight:700;\n    font-size:18px;\n    line-height:1.25;\n    text-transform:uppercase;\n    letter-spacing:.01em;\n    margin:0 0 10px;\n  }\n  .pa-card-text{\n    color:var(--text);\n    font-size:15px;\n    font-weight:500;\n    line-height:1.55;\n    margin:0;\n  }\n\n  .pa-hidden{display:none;}\n  .pa-grid.is-open .pa-hidden{display:block;}\n\n  .pa-cta{text-align:center;margin-top:38px;}\n  .pa-btn{\n    background:var(--navy);\n    color:#fff;border:0;border-radius:40px;\n    padding:15px 36px;font-size:15px;font-weight:700;\n    letter-spacing:.03em;cursor:pointer;\n    transition:background .2s ease,transform .15s ease,box-shadow .2s ease;\n    box-shadow:0 8px 20px rgba(32,67,107,.22);\n  }\n  .pa-btn:hover{background:var(--navy-dark);transform:translateY(-2px);}\n\n  @media(max-width:900px){\n    .pa-grid{grid-template-columns:repeat(2,1fr);}\n  }\n  @media(max-width:600px){\n    .pa-actifs{padding:46px 16px;}\n    .pa-grid{grid-template-columns:1fr;gap:14px;}\n    .pa-card{padding:22px 20px;}\n    .pa-btn{width:100%;}\n  }\n</style>\n\n<script>\n  (function(){\n    var grid=document.getElementById('paGrid');\n    var btn=document.getElementById('paToggle');\n    if(!grid||!btn)return;\n    btn.addEventListener('click',function(){\n      var open=grid.classList.toggle('is-open');\n      btn.textContent=open?'Afficher moins':'Afficher tous les actifs';\n    });\n  })();\n</script>",
